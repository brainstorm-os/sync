# Feedback collector configuration (all optional)

# Listen port
FEEDBACK_PORT=7790

# JSONL retention directory (the source of truth; mount as a volume in Docker)
FEEDBACK_DATA_DIR=./feedback-data

# GitHub issue piping — leave FEEDBACK_GITHUB_REPO empty for JSONL-only mode.
# The token is a fine-grained PAT with Issues read+write on ONLY the inbox repo.
FEEDBACK_GITHUB_REPO=
FEEDBACK_GITHUB_TOKEN=
# "1" = log would-be issues to stderr instead of calling the GitHub API
FEEDBACK_GITHUB_DRY_RUN=

# "1" = disable rate limiting (tests/dev only)
FEEDBACK_LIMITS_DISABLED=
